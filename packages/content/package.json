{
  "name": "@gameish/content",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./canonical": {
      "types": "./src/canonical.ts",
      "default": "./dist/canonical.js"
    },
    "./combat": {
      "types": "./src/combat.ts",
      "default": "./dist/combat.js"
    },
    "./village-map": {
      "types": "./src/village-map-artifact.d.ts",
      "default": "./dist/artifacts/village-map.js"
    },
    "./village-map-server": {
      "types": "./src/village-map-server-artifact.d.ts",
      "default": "./dist/artifacts/village-map.server.js"
    },
    "./village-character": {
      "types": "./src/village-character-artifact.d.ts",
      "default": "./dist/artifacts/village-character.js"
    },
    "./village-combat-server": {
      "types": "./src/village-combat-server-artifact.d.ts",
      "default": "./dist/artifacts/village-combat-server.js"
    },
    "./village-combat": {
      "types": "./src/village-combat-artifact.d.ts",
      "default": "./dist/artifacts/village-combat.js"
    },
    "./dialogue": {
      "types": "./src/dialogue.ts",
      "default": "./dist/dialogue.js"
    },
    "./village-dialogue-server": {
      "types": "./src/village-dialogue-server-artifact.d.ts",
      "default": "./dist/artifacts/village-dialogue-server.js"
    },
    "./village-dialogue": {
      "types": "./src/village-dialogue-artifact.d.ts",
      "default": "./dist/artifacts/village-dialogue.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node dist/compile-canonical-assets.js",
    "typecheck": "tsc -p tsconfig.json",
    "validate": "pnpm build && node dist/validate-canonical.js"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
